# Docker Compose 用环境变量示例（复制为 backend/.env 或在 compose 里 override）
# 容器内访问 postgres / redis 用服务名，不要用 localhost

APP_NAME=FixPilot
APP_VERSION=0.1.0
DEBUG=true

DATABASE_URL=postgresql+asyncpg://fixpilot:fixpilot123@postgres:5432/fixpilot_db
DATABASE_URL_SYNC=postgresql+psycopg2://fixpilot:fixpilot123@postgres:5432/fixpilot_db

REDIS_URL=redis://redis:6379/0
USE_CELERY=true

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/login

OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://api2.aigcbest.top/v1
MODEL_NAME=deepseek-v4-flash

WORKSPACE_BASE_PATH=/app/workspaces
